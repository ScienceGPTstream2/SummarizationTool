# Supabase Docker - Git Ignore

# Runtime data only (not config files)
volumes/db/data/
volumes/storage/

# Environment file (contains secrets)
.env

# Docker overrides (local development customizations)
docker-compose.override.yml

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~

# Tarball (if created)
*.tar.gz
