# Better Auth Service Configuration
# Copy to .env and fill in values

# Database (Azure Postgres Flexible Server)
DATABASE_URL=postgresql://sciencegpt:<PASSWORD>@sciencegptsream2pg.postgres.database.azure.com:5432/summarization_tool?sslmode=require

# Better Auth
BETTER_AUTH_SECRET=generate-a-random-secret-here
BETTER_AUTH_URL=http://localhost:3001

# GitHub Enterprise Cloud OAuth App
# Create at: https://github.com/organizations/<YOUR_ORG>/settings/applications/new
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# CORS — frontend URL
FRONTEND_URL=http://localhost:3000
