# Better Auth Service Configuration
# Copy to .env and fill in values

# Database (Azure Postgres Flexible Server)
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/summarization_tool?sslmode=require

# Better Auth
BETTER_AUTH_SECRET=generate-a-random-secret-here
BETTER_AUTH_URL=http://localhost:3001

# Microsoft Entra ID (Azure AD) — fill in when you have app registration
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# CORS — frontend URL
FRONTEND_URL=http://localhost:5173
