# Frontend Environment Variables
# Copy this file to .env.local and update values as needed
#
# For Vite, variables must be prefixed with VITE_ to be exposed to the frontend

# =============================================================================
# Better Auth Configuration
# =============================================================================
# URL of the Better Auth sidecar service
VITE_AUTH_URL=http://localhost:3001

# =============================================================================
# Backend API Configuration
# =============================================================================
# URL of the FastAPI backend server
VITE_API_BASE_URL=http://localhost:8001
